{
  "expo": {
    "name": "Dungeon Calendar",
    "slug": "dungeon-calendar-mobile",
    "scheme": "dungeoncalendar",
    "version": "1.0.18",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "dark",
    "description": "Dungeon Calendar helps tabletop RPG groups schedule sessions, manage campaigns, track player availability, invite players, and organize adventures.",
    "android": {
      "package": "com.anonymous.dungeoncalendar",
      "versionCode": 18,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "@react-native-google-signin/google-signin"
    ]
  }
}
